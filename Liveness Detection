self):\n        super(LivenessNet, self).__init__()\n        self.network = nn.Sequential(\n            nn.Linear(10, 32),\n            nn.ReLU(),\n            nn.Dropout(0.2), # Standard for preventing overfitting\n            nn.Linear(32, 16),\n            nn.ReLU(),\n            nn.Linear(16, 1) # Single output for Binary Classification\n        )\n    \n    def forward(self, x):\n        return self.network(x)\n\nmodel = LivenessNet()\n# Using BCEWithLogitsLoss because it is more stable (internal Sigmoid included)\ncriterion = nn.BCEWithLogitsLoss() \noptimizer = optim.Adam(model.parameters(), lr=0.001)\n\n# 3. THE TRAINING LOOP (The 5 Golden Lines)\nepochs = 50\nfor epoch in range(epochs):\n    model.train()\n    total_loss = 0\n    for batch_X, batch_y in train_loader:\n        optimizer.zero_grad()           # 1. Reset\n        outputs = model(batch_X)        # 2. Predict\n        loss = criterion(outputs, batch_y)# 3. Calculate Loss\n        loss.backward()                 # 4. Backprop\n        optimizer.step()                # 5. Update Weights\n        total_loss += loss.item()\n    \n    if (epoch + 1) % 10 == 0:\n        print(f\"Epoch [{epoch+1}/{epochs}], Loss: {total_loss/len(train_loader):.4f}\")\n\n# 4. EVALUATION (Critical for Coderbyte)\nmodel.eval()\nwith torch.no_grad():\n    test_outputs = torch.sigmoid(model(X_test_t)) # Manual sigmoid for evaluation\n    predictions = (test_outputs > 0.5).float()\n    print(\"\\n--- FINAL CLASSIFICATION REPORT ---\")\n    print(classification_report(y_test, predictions.numpy(), target_names=['Real', 'Spoof']))\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-13T09:55:32.675302Z","iopub.execute_input":"2026-03-13T09:55:32.675650Z","iopub.status.idle":"2026-03-13T09:55:37.957514Z","shell.execute_reply.started":"2026-03-13T09:55:32.675601Z","shell.execute_reply":"2026-03-13T09:55:37.955972Z"}},"outputs":[{"name":"stdout","text":"Epoch [10/50], Loss: 0.1373\nEpoch [20/50], Loss: 0.1260\nE